# Client (exposed to the browser)
PUBLIC_TURNSTILE_SITE_KEY=

# Server-only (used by src/pages/api/contact.ts — set these in Vercel too)
TURNSTILE_SECRET_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
# EmailJS private key (Account → API keys). Required for server-side calls
# unless "Allow EmailJS API for non-browser applications" is enabled.
EMAILJS_PRIVATE_KEY=
