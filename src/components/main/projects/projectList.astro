---
import { ExpandableCards } from "./ExpandableCards";
import { ui } from "@/lib/ui";
import type { Locale } from "@/data/types";

const { locale = "en" } = Astro.props as { locale?: Locale };
---
  <div class="w-full h-full  flex flex-col pt-5 items-center justify-center ">
      <h2 class="max-w-7xl pl-5 pt-5 pb-2 md:pb-5 text-4xl md:text-5xl font-bold text-neutral-800 dark:text-neutral-200 ">
        {ui.projects.heading[locale]}
      </h2>
      <ExpandableCards client:visible locale={locale} />
      <a
        href="https://github.com/9ero/portfolio-jfernandez-2025"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 text-xs text-neutral-500 dark:text-neutral-400 hover:text-sky-500 dark:hover:text-sky-300 transition-colors"
      >
        {ui.projects.openSource[locale]}
      </a>
  </div>
