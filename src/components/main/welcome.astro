---
import { Spotlight } from "@/components/ui/spotlight-new";
import { profile } from "@/data";
import { ui } from "@/lib/ui";
import type { Locale } from "@/data/types";

const { locale = "en" } = Astro.props as { locale?: Locale };
const summaryLines = profile.summary[locale].split("\n");
---

<div class="h-full w-full sm:rounded-l-md flex items-center md:justify-center bg-gradient-to-b from-zinc-950 to-sky-500 dark:bg-none dark:from-none dark:to-none dark:bg-background antialiased bg-grid-white/[0.02] relative overflow-hidden">
  <Spotlight client:visible />
  <div class="p-4 max-w-7xl mx-auto relative z-10 w-full pt-20 md:pt-0 text-center">
    <h1 class="text-4xl md:text-7xl font-bold bg-clip-text text-transparent bg-gradient-to-b from-lime-200 to-green-400 dark:from-sky-50 dark:to-sky-300 bg-opacity-50">
      {ui.hero.hello[locale]} <br /> {ui.hero.iAm[locale]} {profile.shortName}
    </h1>
    <p class="hero-line mt-6 text-xl md:text-2xl font-semibold text-neutral-100 dark:text-sky-200" style="animation-delay: 0.15s">
      {profile.headline[locale]}
    </p>
    <div class="mt-4 max-w-3xl mx-auto space-y-1">
      {summaryLines.map((line, i) => (
        <p class="hero-line font-normal text-base md:text-lg leading-snug text-neutral-200 dark:text-neutral-300" style={`animation-delay: ${0.35 + i * 0.2}s`}>
          {line}
        </p>
      ))}
    </div>
    <div class="hero-line mt-8 flex flex-wrap items-center justify-center gap-4" style="animation-delay: 1.1s">
      <a
        href="#contact"
        class="rounded-md bg-sky-500 hover:bg-sky-400 text-white font-semibold px-6 py-3 transition-colors"
      >
        {ui.hero.contactMe[locale]}
      </a>
      <a
        href={profile.cv[locale]}
        download
        class="rounded-md border border-sky-300/60 text-sky-100 dark:text-sky-200 hover:bg-sky-500/20 font-semibold px-6 py-3 transition-colors"
      >
        {ui.hero.downloadCV[locale]}
      </a>
    </div>
    <a
      href="https://github.com/9ero/portfolio-jfernandez-2025"
      target="_blank"
      rel="noopener noreferrer"
      class="hero-line mt-6 inline-block text-sm text-neutral-300 dark:text-neutral-400 underline underline-offset-4 decoration-sky-400/60 hover:text-sky-300 transition-colors"
      style="animation-delay: 1.4s"
    >
      {ui.hero.openSource[locale]}
    </a>
  </div>
</div>

<style>
  .hero-line {
    opacity: 0;
    filter: blur(6px);
    animation: hero-reveal 0.7s ease-out forwards;
  }
  @keyframes hero-reveal {
    to {
      opacity: 1;
      filter: blur(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-line {
      animation: none;
      opacity: 1;
      filter: none;
    }
  }
</style>
