---
import '../styles/global.css';
const { content } = Astro.props;
import Header from '@/components/Header.astro';
import { profile, education } from '@/data';
const siteTitle = content?.title || "Juan Miguel Fernández — Infrastructure & Full Stack Engineer · AI Integration";
const siteDescription = content?.description || "Systems and infrastructure generalist with full stack development and production AI integration: AWS, Docker, Python and TypeScript/React. Technical Lead. Complete solutions that run, stay up and protect your data.";
const siteUrl = "https://jfernandezdev.com";
const siteImage = `${siteUrl}/og-cover.webp`;
const author = profile.name;

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: profile.name,
	url: siteUrl,
	email: `mailto:${profile.email}`,
	image: `${siteUrl}${profile.avatar}`,
	jobTitle: "Infrastructure & Full Stack Engineer",
	worksFor: {
		"@type": "Organization",
		name: "Grupo Ecoquintas",
	},
	alumniOf: {
		"@type": "CollegeOrUniversity",
		name: education[0].institution,
	},
	address: {
		"@type": "PostalAddress",
		addressCountry: "CR",
		addressLocality: "Alajuela",
	},
	sameAs: profile.socials.map((s) => s.url),
	knowsAbout: [
		"AWS",
		"Docker",
		"Platform Engineering",
		"DevOps",
		"Python",
		"Flask",
		"TypeScript",
		"React",
		"AI Integration",
		"Model Context Protocol",
	],
};
---

<html lang="en">
	<head>
		<!-- Meta Tags Básicos -->
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO -->
		<title>{siteTitle}</title>
		<meta name="description" content={siteDescription} />
		<meta name="author" content={author} />
		<meta name="keywords" content="Infrastructure Engineer, Platform Engineering, DevOps, Full Stack Engineer, AI Integration, AWS, RDS Aurora, Docker, Python, Flask, TypeScript, React, Next.js, MCP servers, Costa Rica, Remote" />
		<link rel="canonical" href={siteUrl} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={siteDescription} />
		<meta property="og:image" content={siteImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Juan Miguel Fernández — Infrastructure & Full Stack Engineer · AI Integration" />
		<meta property="og:site_name" content={author} />
		<meta property="og:locale" content="en_US" />
		<meta property="og:locale:alternate" content="es_CR" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={siteTitle} />
		<meta name="twitter:description" content={siteDescription} />
		<meta name="twitter:image" content={siteImage} />

		<!-- Structured data -->
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<link rel="apple-touch-icon" href="/logo.svg" />

		<!-- Theme Color -->
		<meta name="theme-color" content="#0ea5e9" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#0c4a6e" media="(prefers-color-scheme: dark)" />

		<!-- Preconnect para mejor performance -->
		<link rel="preconnect" href="https://api.emailjs.com" />
		<link rel="preconnect" href="https://challenges.cloudflare.com" />
	</head>
	<body>
		<Header/>
		<main class="md:ml-[300px] scroll-smooth snap-y snap-mandatory h-screen overflow-y-scroll">
			<slot/>
		</main>
	</body>
</html>
